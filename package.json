{
  "name": "price-tracker-violin-strings",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "seed": "npm run seed -w server",
    "migrate": "npm run migrate -w server",
    "smoke": "npm run smoke -w server",
    "test": "npm run test -w server",
    "build": "npm run build -w client",
    "typecheck": "tsc --noEmit -p server && cd client && tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
