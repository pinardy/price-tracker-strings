# Optional: enables the Reverb marketplace provider.
# Create a token at reverb.com -> My Profile -> API & Integrations -> Generate New Token
REVERB_TOKEN=

# Server port (Vite dev server proxies /api here)
PORT=3001

# Local node-cron schedule; the Vercel deployment uses vercel.json crons instead
FETCH_CRON=0 8 * * *

# Database. Empty -> local file server/data/app-crud.db (no account needed).
# For Turso: DATABASE_URL=libsql://<db>-<org>.turso.io + TURSO_AUTH_TOKEN.
DATABASE_URL=
TURSO_AUTH_TOKEN=

# Shared password for the hosted app. Empty -> gate disabled (local dev).
APP_PASSWORD=

# Only needed on Vercel: authenticates the daily cron invocation.
CRON_SECRET=
